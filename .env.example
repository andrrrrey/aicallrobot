# === Yandex Cloud (обязательно — без ключей робот не говорит и не слышит) ===
YANDEX_API_KEY=
YANDEX_FOLDER_ID=

# === SaluteSpeech (опционально, альтернативный голос) ===
SALUTESPEECH_AUTH_KEY=

# === Приложение ===
APP_ENV=production
LOG_LEVEL=INFO
MAX_CONCURRENT_CALLS=3

# === PostgreSQL (база клиентов и состояние обзвона) ===
# В docker-compose хост = postgres. Для локального запуска — localhost.
DATABASE_URL=postgresql+asyncpg://robot:robot@postgres:5432/airobot

# === SIP-регистрация робота как экстеншена на АТС заказчика (через VPN) ===
SIP_SERVER=192.168.0.110
SIP_EXTENSION=
SIP_PASSWORD=
SIP_CONTEXT=
SIP_CODEC=pcma

# === HTTP-API res24.php (инициирование звонка + статус/CDR) ===
RES24_BASE_URL=http://192.168.0.110
RES24_LOGIN=robott
RES24_SECRET=
# Экстеншен робота, который подставляется в параметр from при res24 call
ROBOT_EXTENSION=

# === AMI (опционально) ===
AMI_HOST=192.168.0.110
AMI_PORT=5038
AMI_USER=robott
AMI_SECRET=

# === Набор номеров и лимиты транков ===
# Национальный префикс для res24 `to` (8 или 7)
DIAL_NATIONAL_PREFIX=8
# t2 (SIP-GSM) — 1 линия; местные через «Телезон» — до 30
ROUTE_LIMIT_T2=1
ROUTE_LIMIT_LOCAL=30

# === Диалер ===
DIALER_ENABLED=false
DIALER_POLL_INTERVAL=5.0
MAX_RETRIES=3
RETRY_BACKOFF_BASE=300.0
