# === ВАРИАНТ 1: Есть домен ===
# Замените YOURDOMAIN.RU на ваш домен, направленный на IP сервера.
# Caddy автоматически получит SSL-сертификат от Let's Encrypt.
#
# YOURDOMAIN.RU {
#     reverse_proxy ai-robot:8000
# }

# === ВАРИАНТ 2: Нет домена — self-signed сертификат ===
# Работает по IP. Браузер покажет предупреждение один раз —
# нажать «Дополнительно» → «Перейти на сайт».
# После этого микрофон будет работать.

:443 {
    tls internal
    reverse_proxy ai-robot:8000
}
